<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ned Dispatch – Professional freight dispatch for reefer, dry van, flatbed, and car hauling. Nationwide coverage, on-time every time." />
    <meta property="og:title" content="NEDispatch – Freight Dispatch Services" />
    <meta property="og:description" content="Professional freight dispatch for reefer, dry van, flatbed, and car hauling. Nationwide coverage, on-time every time." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="NEDispatch – Freight Dispatch Services" />
    <meta name="twitter:description" content="Professional freight dispatch for reefer, dry van, flatbed, and car hauling. Nationwide coverage, on-time every time." />
    <!-- Replace with your own hero/share image when ready -->
    <meta property="og:image" content="https://images.unsplash.com/photo-1519003722824-194d4455a60c?w=1200" />
    <meta name="twitter:image" content="https://images.unsplash.com/photo-1519003722824-194d4455a60c?w=1200" />
    <title>NEDispatch – Freight Dispatch Services</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'ned-bg': '#1a1a1a',
              'ned-card': '#2b2b2b',
              'ned-accent': '#3498db',
              'ned-accent-dark': '#2980b9',
            },
          },
        },
      };
    </script>
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="stylesheet" href="reset.css" />
    <link rel="stylesheet" href="style.css" />
    <script src="script.js" defer></script>
  </head>
  <body class="bg-ned-bg text-white min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <a href="#" class="logo">
        <span class="logo-text"><span class="logo-ned">NED</span><span class="logo-ispatch">ispatch</span></span>
      </a>
      <nav class="main-nav" aria-label="Main navigation">
        <a href="#home">Home</a>
        <div class="nav-dropdown">
          <a href="#services" class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false" id="services-menu">Services</a>
          <ul class="nav-dropdown-menu" aria-labelledby="services-menu">
            <li><a href="#service-reefer">Reefer</a></li>
            <li><a href="#service-dryvan">Dry Van</a></li>
            <li><a href="#service-car">Car Hauling</a></li>
            <li><a href="#service-flatbed">Flatbed</a></li>
          </ul>
        </div>
        <a href="#about">About</a>
        <a href="#gallery">Gallery</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Contact</a>
      </nav>
      <a href="#contact" class="btn btn-cta header-cta">Get a Quote</a>
      <button type="button" class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" id="menu-toggle-btn">
        <span class="menu-toggle-bar"></span>
        <span class="menu-toggle-bar"></span>
        <span class="menu-toggle-bar"></span>
      </button>
    </header>
    <div class="mobile-only-banner">
      <div class="container mobile-only-banner-inner">
        <span class="mobile-only-label">{{ site.mobileBanner.label }}</span>
        <a href="{{ site.mobileBanner.phoneHref }}" class="mobile-only-phone">{{ site.mobileBanner.phoneLabel }}</a>
      </div>
    </div>
    <div class="mobile-menu-overlay" id="mobile-menu-overlay" aria-hidden="true"></div>
    <div class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation" aria-hidden="true">
      <nav class="mobile-nav" aria-label="Mobile primary navigation">
        <a href="#home" class="mobile-nav-link">Home</a>
        <a href="#services" class="mobile-nav-link">Services</a>
        <a href="#service-reefer" class="mobile-nav-sublink">Reefer</a>
        <a href="#service-dryvan" class="mobile-nav-sublink">Dry Van</a>
        <a href="#service-car" class="mobile-nav-sublink">Car Hauling</a>
        <a href="#service-flatbed" class="mobile-nav-sublink">Flatbed</a>
        <a href="#about" class="mobile-nav-link">About</a>
        <a href="#gallery" class="mobile-nav-link">Gallery</a>
        <a href="#faq" class="mobile-nav-link">FAQ</a>
        <a href="#contact" class="mobile-nav-link">Contact</a>
        <a href="#contact" class="btn btn-primary mobile-menu-cta">Get a Quote</a>
      </nav>
    </div>

    <main id="main-content">
      <section id="home" class="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content container hero-entrance">
          <p class="hero-label">{{ site.hero.label }}</p>
          <h1 class="hero-title">
            {{ site.hero.title | replace("Forward", "") }}<span class="accent">Forward</span>
          </h1>
          <p class="hero-desc">
            {{ site.hero.description }}
          </p>
          <div class="hero-buttons">
            <a href="{{ site.hero.primaryCtaHref }}" class="btn btn-primary">{{ site.hero.primaryCtaText }}</a>
            <a href="{{ site.hero.secondaryCtaHref }}" class="btn btn-secondary">{{ site.hero.secondaryCtaText }}</a>
          </div>
        </div>
      </section>

      <section id="about" class="about section section-reveal">
        <div class="container about-grid">
          <div class="about-content">
            <p class="section-label">ABOUT US</p>
            <h2 class="section-title">{{ site.about.title }}</h2>
            <p>{{ site.about.paragraph1 }}</p>
            <p>{{ site.about.paragraph2 }}</p>
          </div>
          <div class="about-stats">
            {% for stat in site.stats %}
            <article class="stat-card">
              <div class="stat-icon{% if stat.icon == 'clock' %} stat-icon-clock{% elseif stat.icon == 'location' %} stat-icon-location{% endif %}" aria-hidden="true">
                {% if stat.icon == 'shield' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {% elseif stat.icon == 'clock' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                {% elseif stat.icon == 'location' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {% endif %}
              </div>
              <div class="stat-content">
                <span class="stat-value">{{ stat.value }}</span>
                <span class="stat-label">{{ stat.label }}</span>
              </div>
            </article>
            {% endfor %}
          </div>
        </div>
      </section>

      <section id="services" class="services section section-reveal">
        <div class="container">
          <p class="section-label section-label-center">WHAT WE HAUL</p>
          <h2 class="section-title section-title-center">Our Services</h2>
          <div class="services-grid">
            {% for service in site.services %}
            <article id="{{ service.id }}" class="service-card">
              <div class="service-photo">
                <img src="{{ service.image }}" alt="{{ service.name }} service" width="200" height="120" loading="lazy" />
              </div>
              <h3 class="service-title">{{ service.name }}</h3>
              <p class="service-desc">
                {{ service.description }}
              </p>
            </article>
            {% endfor %}
          </div>
        </div>
      </section>

      <section id="testimonials" class="testimonials section section-reveal">
        <div class="container">
          <p class="section-label section-label-center">WHAT PEOPLE SAY</p>
          <h2 class="section-title section-title-center">Testimonials</h2>
          <div class="testimonials-grid">
            {% for t in site.testimonials %}
            <blockquote class="testimonial-card">
              <p class="testimonial-quote">{{ t.quote }}</p>
              <footer class="testimonial-footer">
                <span class="testimonial-avatar" aria-hidden="true">{{ t.initials }}</span>
                <div>
                  <cite class="testimonial-name">{{ t.name }}</cite>
                  <span class="testimonial-role">{{ t.role }}</span>
                </div>
              </footer>
            </blockquote>
            {% endfor %}
          </div>
        </div>
      </section>

      <section class="trust-strip section">
        <div class="container">
          <p class="trust-strip-label">{{ site.trust.label }}</p>
          <div class="trust-strip-logos" aria-hidden="true">
            {% for label in site.trust.logos %}
            <span class="trust-logo">{{ label }}</span>
            {% endfor %}
          </div>
        </div>
      </section>

      <section id="gallery" class="gallery section section-reveal">
        <div class="container">
          <p class="section-label section-label-center">FLEET & FREIGHT</p>
          <h2 class="section-title section-title-center">Gallery</h2>
          <div class="gallery-grid">
            {% for image in site.gallery %}
            <div class="gallery-item">
              <img src="{{ image }}" alt="NEDispatch fleet" width="400" height="300" loading="lazy" />
            </div>
            {% endfor %}
          </div>
        </div>
      </section>

      <section id="faq" class="faq section section-reveal">
        <div class="container faq-container">
          <p class="section-label section-label-center">GOT QUESTIONS?</p>
          <h2 class="section-title section-title-center">FAQ</h2>
          <div class="faq-list">
            {% for item in site.faq %}
            <details class="faq-item">
              <summary>{{ item.question }}</summary>
              <p>{{ item.answer }}</p>
            </details>
            {% endfor %}
          </div>
        </div>
      </section>

      <section id="contact" class="contact section section-reveal">
        <div class="container">
          <p class="section-label section-label-center">GET IN TOUCH</p>
          <h2 class="section-title section-title-center">Contact Us</h2>
          <div class="contact-grid">
            <div class="contact-info">
              <div class="contact-item">
                <div class="contact-icon contact-icon-phone" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <h3 class="contact-item-title">Phone</h3>
                  <p class="contact-item-text">{{ site.contact.phone }}</p>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon contact-icon-email" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
                </div>
                <div>
                  <h3 class="contact-item-title">Email</h3>
                  <p class="contact-item-text">{{ site.contact.email }}</p>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon contact-icon-location" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <h3 class="contact-item-title">Location</h3>
                  <p class="contact-item-text">{{ site.contact.location }}</p>
                </div>
              </div>
            </div>
            <form id="contact-form" class="contact-form" action="#" method="post">
              <div class="form-row">
                <input type="text" name="name" placeholder="Your Name" required />
                <input type="email" name="email" placeholder="Email Address" required />
              </div>
              <input type="tel" name="phone" placeholder="Phone Number" />
              <textarea name="message" rows="4" placeholder="Tell us about your freight needs..."></textarea>
              <p id="form-message" class="form-message" aria-live="polite" hidden></p>
              <button type="submit" id="form-submit" class="btn btn-primary btn-submit">
                <span class="btn-text">Send Message</span>
                <span class="btn-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                </span>
              </button>
            </form>
          </div>
        </div>
      </section>

      <section class="cta-strip section">
        <div class="container cta-strip-inner">
          <h2 class="cta-strip-title">{{ site.ctaStrip.title }}</h2>
          <a href="{{ site.ctaStrip.buttonHref }}" class="btn btn-primary btn-cta-strip">{{ site.ctaStrip.buttonText }}</a>
        </div>
      </section>
    </main>

    <div id="sticky-cta" class="sticky-cta" aria-hidden="true">
      <a href="#contact" class="btn btn-primary">Get a Quote</a>
    </div>

    <a href="#contact" class="mascot" aria-label="NEDi, your dispatch buddy">
      <div class="mascot-body" aria-hidden="true">
        <img src="images/footer.webp" alt="" class="mascot-image" loading="lazy" />
      </div>
      <div class="mascot-bubble">
        <p>Hi, I&apos;m NEDi – ready to keep your loads moving. Need a quote?</p>
      </div>
    </a>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-copy">&copy; {{ site.footer.year }} {{ site.footer.company }}. All rights reserved.</p>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="#services">Services</a>
          <a href="#about">About</a>
          <a href="#gallery">Gallery</a>
          <a href="#faq">FAQ</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </footer>
    <a href="#main-content" class="back-to-top" aria-label="Back to top">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 15l-6-6-6 6" />
      </svg>
    </a>
  </body>
</html>

